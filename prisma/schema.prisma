generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum OrderStatus {
  PENDING      // Order created, waiting for payment/confirmation
  CONFIRMED    // Payment verified, order accepted
  PROCESSING   // Being prepared
  SHIPPED      // Handed over to courier
  DELIVERED    // Successfully received
  CANCELLED    // Cancelled by user or admin
  RETURNED     // Item returned by customer
}

enum PaymentStatus {
  PENDING
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
  FAILED
}

enum AddressType {
  HOME
  WORK
  OTHER
}
enum CategoryType{
  ITEM
  ROLE
}

enum OfferType {
  OFFER
  COUPON
}

enum DiscountType {
  FLAT        // Flat ₹X discount
  PERCENTAGE  // X% off
  BOGO        // Buy One Get One (or N+M)
}

enum OfferScope {
  ITEM
  CART
}


enum SubscriptionSource {
  FOOTER
  POPUP
  CHECKOUT
  CAMPAIGN
  MANUAL
}
enum ImageOwnerType {
  USER
  ITEM_THUMBNAIL    // item-thumbnail-image
  ITEM_GALLERY      // item-gallery-images
  BRANCH            // branch-images
  REVIEW            // review-images
  CATEGORY_BANNER  // main hero / banner image of a category
  CATEGORY_IMAGE   // square thumbnail / icon image of a category
  BANNER
}



model User {
  id          String       @id @default(uuid())
  firstname   String
  lastname    String?
  phone       String?    @unique
  email       String    @unique
  password    String?
  isPremium   Boolean   @default(false)
  isVerified  Boolean    @default(false)
  role        UserRole   @default(CUSTOMER)
  orders      Order[]
  cartItems   CartItem[]
  addresses   Address[]  // new: multiple addresses
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isActive    Boolean    @default(true)
  // Employees only (optional)
  employee   Employee?   // ← null for customers
  images     Image[]
  reviews    Review[]
  carts      Cart[]
  // Add these
  favourites    UserFavourite[]
  wishlists     UserWishlist[]

  // Relations for CategoryMaster
  categoriesCreated CategoryMaster[] @relation("CategoryCreator")
  categoriesUpdated CategoryMaster[] @relation("CategoryUpdater")
  ItemsCreated Item[] @relation("ItemCreator")
  ItemsUpdated Item[] @relation("ItemUpdater")
  offersCreated OfferMaster[] @relation("OfferCreator")
  offersUpdated OfferMaster[] @relation("OfferUpdater")
  bannersCreated Banner[] @relation("BannerCreator")
  bannersUpdated Banner[] @relation("BannerUpdater")
  @@unique([email, phone]) // Composite unique constraint
  @@index([isActive])
}

model Address {
  id          String       @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  receiverName String
  type         AddressType @default(HOME)
  line1        String
  line2        String? 
  city         String
  state        String
  country      String
  postalCode   String
  latitude     String?
  longitude    String?
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([city])
  @@index([state])
  @@index([country])
  @@index([postalCode])
  @@index([isDefault])
}

model CategoryMaster {
  id          String        @id @default(uuid())
  name        String        @unique
  image       String?
  description String?
  isActive    Boolean       @default(true)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedBy   String
  updatedAt   DateTime      @updatedAt
  user        User          @relation("CategoryCreator", fields: [createdBy], references: [id])
  updater     User          @relation("CategoryUpdater", fields: [updatedBy], references: [id])
  items       Item[]        // One-to-many
  images      Image[]       // One-to-many (category banner / thumbnail images)
  @@index([isActive])
  @@index([createdBy])
  @@index([updatedBy])
}

model OfferMaster {
  id          String       @id @default(uuid())
  name        String
  description String?
  type        OfferType
  validFrom   DateTime
  validUpto   DateTime
  discountType DiscountType    // FLAT, PERCENTAGE, BOGO, etc.
  discountValue Float?          // e.g. 10%
  maxDiscountAmount Float?         // e.g. upto ₹100
  minPurchaseAmount Float?     // cart level condition
  minQuantity Int?             // item level condition
  maxFreeQuantity Int?             // item level condition
  applicableScope OfferScope   // ITEM or CART
  isActive    Boolean       @default(true)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedBy   String
  updatedAt   DateTime      @updatedAt
  user        User          @relation("OfferCreator", fields: [createdBy], references: [id])
  updater     User          @relation("OfferUpdater", fields: [updatedBy], references: [id])
  isStackable Boolean @default(false)

  // Relations
  items       Item[]           
  orders      Order[]
  @@index([isActive])
  @@index([isActive, validFrom, validUpto])
  @@index([createdBy])
  @@index([updatedBy])     
  @@index([discountValue])
  @@index([discountType]) 
  @@index([type])
  @@index([validFrom, validUpto])          
}

model Item {
  id          String       @id @default(uuid())
  name        String
  description String?
  image       String?
  price       Float
  categoryId  String
  rating      Int           @default(0)
  offerId     String?       
  offer       OfferMaster?   @relation(fields: [offerId], references: [id])
  isAvailable Boolean       @default(true)
  isActive    Boolean       @default(true)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedBy   String
  updatedAt   DateTime      @updatedAt
  user        User          @relation("ItemCreator", fields: [createdBy], references: [id])
  updater     User          @relation("ItemUpdater", fields: [updatedBy], references: [id])
  category    CategoryMaster   @relation(fields: [categoryId], references: [id])
  inventories Inventory[]  // one item can be in multiple branches' inventory
  orderItems  OrderItem[]
  cartItems   CartItem[]
   // Relationships
  reviews     Review[]  // One-to-many
  images      Image[]   // One-to-many
  // Add these
  favourites    UserFavourite[]
  wishlists     UserWishlist[]


  @@index([isActive])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([categoryId])
  @@index([offerId])
  @@index([price])
  @@index([rating])   
  @@index([categoryId, isAvailable, isActive, price])   
  @@index([categoryId, rating])
}
model UserFavourite {
  id        String   @id @default(uuid())
  userId    String
  itemId    String

  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, itemId])       // Prevent duplicate favourites
  @@index([userId])
  @@index([itemId])
}
model UserWishlist {
  id        String   @id @default(uuid())
  userId    String
  itemId    String

  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, itemId])       // Prevent duplicate wishlist entries
  @@index([userId])
  @@index([itemId])
}


model CartItem {
  id          String       @id @default(uuid())
  quantity  Int      @default(0)
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  guestId   String?  
  item      Item     @relation(fields: [itemId], references: [id])
  itemId    String
  cart      Cart     @relation(fields: [cartId], references: [id])
  cartId    String
  addedAt   DateTime @default(now())
  @@unique([userId, itemId]) // Composite unique constraint
  @@unique([guestId, itemId]) // ✅ Added guest constraint
  @@index([cartId])
  @@index([userId, itemId]) // Composite index constraint
  @@index([guestId, itemId])
}

model Order {
  id               String        @id @default(uuid())
  orderNumber      String        @unique // Human readable e.g. EX-10001
  userId           String
  totalAmount      Decimal       @db.Decimal(10, 2)
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(UNPAID)
  
  // 📸 Snapshots
  shippingAddress  Json          
  
  // Relations preserved from previous schema
  branchId         String
  branch           Branch      @relation(fields: [branchId], references: [id])
  couponId         String?
  coupon           OfferMaster? @relation(fields: [couponId], references: [id])

  // Audit & Tracking
  notes            String?       // Admin or User notes
  trackingNumber   String?
  courierPartner   String?

  // Relations
  user             User          @relation(fields: [userId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([branchId])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  itemId          String
  quantity        Int
  
  // 📸 Price Snapshot at time of purchase
  priceAtPurchase Decimal  @db.Decimal(10, 2)
  
  // Metadata Snapshots
  itemName        String?
  itemThumbnail   String?
  
  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item            Item     @relation(fields: [itemId], references: [id])

  @@index([orderId])
  @@index([itemId])
  @@map("order_items")
}

model Payment {
  id               String   @id @default(uuid())
  orderId          String
  amount           Decimal  @db.Decimal(10, 2)
  
  // Provider Info
  provider         String   @default("MANUAL") // MANUAL, STRIPE, COD, etc.
  transactionId    String?  @unique           // External reference ID
  paymentMethod    String?                    // CARD, UPI, CASH
  
  status           PaymentStatus @default(PENDING)
  
  // Flexible Audit Data for reports
  paymentMetadata  Json?    @default("{}")

  // Relations
  order            Order    @relation(fields: [orderId], references: [id])
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId])
  @@map("payments")
}

model Branch {
  id      String      @id @default(uuid())
  name    String
  address String
  city    String
  state   String
  phone   String
  createdAt DateTime @default(now())

  inventory Inventory[]
  orders    Order[]
  employees Employee[]  // not User[]
   // Relationships
  reviews     Review[]  // One-to-many
  images      Image[]   // One-to-many
}

model Inventory {
  id        String      @id @default(uuid())
  itemId    String
  branchId  String
  quantity  Int
  updatedAt DateTime @updatedAt

  item      Item   @relation(fields: [itemId], references: [id])
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Employee {
  id          String      @id @default(uuid())
  userId       String     @unique
  branchId     String
  position     String  // like 'cashier', 'manager', etc.
  companyEmail String?
  isActive     Boolean  @default(true)
  user         User    @relation(fields: [userId], references: [id])
  branch       Branch  @relation(fields: [branchId], references: [id])
  @@index([branchId])
  @@index([isActive])
}


model JoinUs{
  id    String      @id @default(uuid())
  name String
  email String
}

model ContactUs{
  id    String      @id @default(uuid())
  name String
  email String
  subject String?
}

model Image {
  id          String         @id @default(uuid())
  imageUrl    String         @db.Text
  publicId    String         @unique
  ownerType   ImageOwnerType  // ← tells the API which FK is active
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  itemId      String?
  item        Item?          @relation(fields: [itemId], references: [id])
  branchId    String?
  branch      Branch?        @relation(fields: [branchId], references: [id])
  reviewId    String?
  review      Review?        @relation(fields: [reviewId], references: [id])
  categoryId  String?
  category    CategoryMaster? @relation(fields: [categoryId], references: [id])
  bannerId    String?
  banner      Banner?        @relation(fields: [bannerId], references: [id])
  uploadedAt  DateTime       @default(now())
  @@index([ownerType, userId])     // fetch all images for a user instantly
  @@index([ownerType, itemId])     // fetch all images for an item instantly
  @@index([ownerType, branchId])
  @@index([ownerType, reviewId])
  @@index([ownerType, categoryId])  // fetch all images for a category instantly
  @@index([ownerType, bannerId])
}

model Review {
  id         String      @id @default(uuid())
  content    String
  rating     Int      // Rating between 1–5
  user       User     @relation(fields: [userId], references: [id])
  userId     String

  item       Item?    @relation(fields: [itemId], references: [id])
  itemId     String?

  branch     Branch?  @relation(fields: [branchId], references: [id])
  branchId   String?

  images     Image[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, itemId])    // one review per user per item
  @@unique([userId, branchId])  // one review per user per branch
  @@index([itemId])
  @@index([branchId])
  @@index([userId])
  @@index([rating])
}
model Cart {
  id        String      @id @default(uuid())
  name      String     // Optional: "Bulk Order", "Gift", etc.
  user      User?       @relation(fields: [userId], references: [id])
  userId    String?
  guestId   String?    
  createdAt DateTime   @default(now())
  isActive  Boolean    @default(true)

  items     CartItem[]
  @@unique([userId, isActive])
  @@unique([guestId, isActive]) // ✅ Added guest constraint

  @@index([userId])
  @@index([guestId])
  @@index([isActive])
}


model NewsletterSubscriber {
  id                String   @id @default(uuid())

  // Core identity
  email             String   @unique
  name              String?
  phone             String?

  // Funnel & lifecycle
  isActive           Boolean  @default(true)
  isUser             Boolean  @default(false)

  source             SubscriptionSource

  // Segmentation & analytics
  tags               Json?
  subscribedAt       DateTime @default(now())
  unsubscribedAt     DateTime?

  lastEmailSentAt    DateTime?

  @@index([isActive])
  @@index([isUser])
  @@index([source])
}

// ─────────────────────────────────────────────────────────────────────────────
// Activity / Audit Log
// ─────────────────────────────────────────────────────────────────────────────

// Every discrete action the system can perform
enum ActivityType {
  // ── Auth ──────────────────────────────────────────────────────────────────
  REGISTER            // new user signs up
  LOGIN               // successful login (OTP or password path)
  LOGOUT              // explicit logout / session invalidation
  LOGIN_FAILED        // wrong OTP / password attempt
  OTP_REQUESTED       // OTP email dispatched
  OTP_VERIFIED        // OTP accepted
  PASSWORD_CHANGE_OTP // password-change OTP requested
  PASSWORD_CHANGED    // password updated successfully
  TOKEN_REFRESHED     // silent refresh-token exchange
  ACCOUNT_DEACTIVATED // user / admin deactivates an account

  // ── CRUD core ─────────────────────────────────────────────────────────────
  CREATE              // generic create
  READ                // generic fetch / read
  UPDATE              // generic update / patch
  DELETE              // generic delete (hard)
  SOFT_DELETE         // isActive toggled to false
  RESTORE             // isActive toggled back to true

  // ── Order lifecycle ───────────────────────────────────────────────────────
  ORDER_PLACED
  ORDER_PROCESSING
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED

  // ── Inventory ─────────────────────────────────────────────────────────────
  INVENTORY_UPDATED   // stock count changed at a branch

  // ── Media ─────────────────────────────────────────────────────────────────
  IMAGE_UPLOADED
  IMAGE_DELETED

  // ── Cart ──────────────────────────────────────────────────────────────────
  CART_ITEM_ADDED
  CART_ITEM_REMOVED
  CART_ITEM_UPDATED
  CART_CLEARED

  // ── Reviews ───────────────────────────────────────────────────────────────
  REVIEW_SUBMITTED
  REVIEW_UPDATED
  REVIEW_DELETED

  // ── Offers / Coupons ──────────────────────────────────────────────────────
  OFFER_APPLIED
  OFFER_REMOVED

  // ── Newsletter ────────────────────────────────────────────────────────────
  NEWSLETTER_SUBSCRIBED
  NEWSLETTER_UNSUBSCRIBED

  // ── Misc / Admin ──────────────────────────────────────────────────────────
  EXPORT              // data exported (CSV, PDF, etc.)
  IMPORT              // bulk import
  SETTINGS_CHANGED    // system-level config changes
}

// Who / what access level triggered the activity
enum ActorType {
  CUSTOMER    // registered customer (UserRole.CUSTOMER)
  EMPLOYEE    // branch-level employee
  MANAGER     // branch / ops manager
  ADMIN       // platform admin
  SYSTEM      // automated / background job (cron, webhook, etc.)
  GUEST       // unauthenticated / guest session
}

// Which table / domain the activity was performed on
enum EntityType {
  USER
  ADDRESS
  CATEGORY
  ITEM
  INVENTORY
  ORDER
  ORDER_ITEM
  CART
  CART_ITEM
  REVIEW
  IMAGE
  OFFER
  BRANCH
  EMPLOYEE
  NEWSLETTER_SUBSCRIBER
  FAVOURITE
  WISHLIST
  BANNER
  AUTH               // auth-scoped events (login, OTP, token refresh)
  SYSTEM             // platform-wide settings / exports / imports
}

model ActivityLog {
  id          String       @id @default(uuid())

  // What happened
  type        ActivityType

  // Who did it
  actorType   ActorType
  actorId     String?      // userId if applicable; null for SYSTEM / GUEST

  // On what entity
  entityType  EntityType
  entityId    String?      // primary key of the affected row; null for list fetches

  // Extra context (diff, filters, meta, error message, etc.)
  meta        Json?

  // Request traceability
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime     @default(now())

  @@index([type])
  @@index([actorId])
  @@index([actorType])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorId, createdAt])       // timeline for a specific user
  @@index([entityType, type, createdAt]) // audit trail per entity type
}
model Banner {
  id          String   @id @default(uuid())
  title       String
  description String?
  link        String?  // Link to a product, category, or external URL
  imageUrl    String?  // Main image URL
  isActive    Boolean  @default(true) // For lifecycle management (deactivate/restore)
  isOngoing   Boolean  @default(true) // For turning on/off manually
  startDate   DateTime?
  endDate     DateTime?
  priority    Int      @default(0) // For sorting in the carousel
  createdBy   String
  createdAt   DateTime @default(now())
  updatedBy   String
  updatedAt   DateTime @updatedAt
  user        User     @relation("BannerCreator", fields: [createdBy], references: [id])
  updater     User     @relation("BannerUpdater", fields: [updatedBy], references: [id])
  images      Image[]  // Relation to images table
  
  @@index([isActive])
  @@index([isOngoing])
  @@index([startDate, endDate])
  @@index([priority])
  @@index([createdBy])
  @@index([updatedBy])
}

// ─── App Configuration ───────────────────────────────────────────────────────
model AppData {
  id            String   @id @default(uuid())
  appName       String   @default("Exotix")
  appVersion    String   @default("1.0.0")
  domainUrl     String?
  contactEmail  String?
  contactPhone  String?
  metadata      Json?    @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("app_data")
}
