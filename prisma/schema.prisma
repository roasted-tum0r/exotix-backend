generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AddressType {
  HOME
  WORK
  OTHER
}
enum CategoryType{
  ITEM
  ROLE
}

enum OfferType {
  OFFER
  COUPON
}

enum DiscountType {
  FLAT        // Flat ₹X discount
  PERCENTAGE  // X% off
  BOGO        // Buy One Get One (or N+M)
}

enum OfferScope {
  ITEM
  CART
}


enum SubscriptionSource {
  FOOTER
  POPUP
  CHECKOUT
  CAMPAIGN
  MANUAL
}
enum ImageOwnerType {
  USER
  ITEM
  BRANCH
  REVIEW
}



model User {
  id          String       @id @default(uuid())
  firstname   String
  lastname    String?
  phone       String?    @unique
  email       String    @unique
  password    String?
  isPremium   Boolean   @default(false)
  isVerified  Boolean    @default(false)
  role        UserRole   @default(CUSTOMER)
  orders      Order[]
  cartItems   CartItem[]
  addresses   Address[]  // new: multiple addresses
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isActive    Boolean    @default(true)
  // Employees only (optional)
  employee   Employee?   // ← null for customers
  images     Image[]
  reviews    Review[]
  carts      Cart[]
  // Add these
  favourites    UserFavourite[]
  wishlists     UserWishlist[]

  // Relations for CategoryMaster
  categoriesCreated CategoryMaster[] @relation("CategoryCreator")
  categoriesUpdated CategoryMaster[] @relation("CategoryUpdater")
  ItemsCreated Item[] @relation("ItemCreator")
  ItemsUpdated Item[] @relation("ItemUpdater")
  offersCreated OfferMaster[] @relation("OfferCreator")
  offersUpdated OfferMaster[] @relation("OfferUpdater")
  @@unique([email, phone]) // Composite unique constraint
  @@index([isActive])
}

model Address {
  id          String       @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  receiverName String
  type         AddressType @default(HOME)
  line1        String
  line2        String? 
  city         String
  state        String
  country      String
  postalCode   String
  latitude     String?
  longitude    String?
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Optional: orders using this address for shipping/billing
  OrdersAsShipping Order[]  @relation("ShippingAddress")
  OrdersAsBilling  Order[]  @relation("BillingAddress")
  @@index([userId])
  @@index([city])
  @@index([state])
  @@index([country])
  @@index([postalCode])
  @@index([isDefault])
}

model CategoryMaster {
  id          String        @id @default(uuid())
  name        String        @unique
  image       String?
  description String?
  isActive    Boolean       @default(true)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedBy   String
  updatedAt   DateTime      @updatedAt
  user        User          @relation("CategoryCreator", fields: [createdBy], references: [id])
  updater     User          @relation("CategoryUpdater", fields: [updatedBy], references: [id])
  items       Item[]        // One-to-many
  @@index([isActive])
  @@index([createdBy])
  @@index([updatedBy])
}

model OfferMaster {
  id          String       @id @default(uuid())
  name        String
  description String?
  type        OfferType
  validFrom   DateTime
  validUpto   DateTime
  discountType DiscountType    // FLAT, PERCENTAGE, BOGO, etc.
  discountValue Float?          // e.g. 10%
  maxDiscountAmount Float?         // e.g. upto ₹100
  minPurchaseAmount Float?     // cart level condition
  minQuantity Int?             // item level condition
  maxFreeQuantity Int?             // item level condition
  applicableScope OfferScope   // ITEM or CART
  isActive    Boolean       @default(true)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedBy   String
  updatedAt   DateTime      @updatedAt
  user        User          @relation("OfferCreator", fields: [createdBy], references: [id])
  updater     User          @relation("OfferUpdater", fields: [updatedBy], references: [id])
  isStackable Boolean @default(false)

  // Relations
  items       Item[]           
  orders      Order[]
  @@index([isActive])
  @@index([isActive, validFrom, validUpto])
  @@index([createdBy])
  @@index([updatedBy])     
  @@index([discountValue])
  @@index([discountType]) 
  @@index([type])
  @@index([validFrom, validUpto])          
}

model Item {
  id          String       @id @default(uuid())
  name        String
  description String?
  image       String?
  price       Float
  categoryId  String
  rating      Int           @default(0)
  offerId     String?       
  offer       OfferMaster?   @relation(fields: [offerId], references: [id])
  isAvailable Boolean       @default(true)
  isActive    Boolean       @default(true)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedBy   String
  updatedAt   DateTime      @updatedAt
  user        User          @relation("ItemCreator", fields: [createdBy], references: [id])
  updater     User          @relation("ItemUpdater", fields: [updatedBy], references: [id])
  category    CategoryMaster   @relation(fields: [categoryId], references: [id])
  inventories Inventory[]  // one item can be in multiple branches' inventory
  orderItems  OrderItem[]
  cartItems   CartItem[]
   // Relationships
  reviews     Review[]  // One-to-many
  images      Image[]   // One-to-many
  // Add these
  favourites    UserFavourite[]
  wishlists     UserWishlist[]


  @@index([isActive])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([categoryId])
  @@index([offerId])
  @@index([price])
  @@index([rating])   
  @@index([categoryId, isAvailable, isActive, price])   
  @@index([categoryId, rating])
}
model UserFavourite {
  id        String   @id @default(uuid())
  userId    String
  itemId    String

  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, itemId])       // Prevent duplicate favourites
  @@index([userId])
  @@index([itemId])
}
model UserWishlist {
  id        String   @id @default(uuid())
  userId    String
  itemId    String

  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, itemId])       // Prevent duplicate wishlist entries
  @@index([userId])
  @@index([itemId])
}


model CartItem {
  id          String       @id @default(uuid())
  quantity  Int      @default(0)
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  guestId   String?  
  item      Item     @relation(fields: [itemId], references: [id])
  itemId    String
  cart      Cart     @relation(fields: [cartId], references: [id])
  cartId    String
  addedAt   DateTime @default(now())
  @@unique([userId, itemId]) // Composite unique constraint
  @@unique([guestId, itemId]) // ✅ Added guest constraint
  @@index([cartId])
  @@index([userId, itemId]) // Composite index constraint
  @@index([guestId, itemId])
}

model Order {
  id                 String      @id @default(uuid())
  user               User        @relation(fields: [userId], references: [id])
  userId             String
  coupon             OfferMaster? @relation(fields: [couponId], references: [id])
  couponId           String?
  status             OrderStatus @default(PENDING)
  totalAmount        Float
  placedAt           DateTime    @default(now())

  branch             Branch      @relation(fields: [branchId], references: [id])
  branchId           String
  shippingAddress    Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  shippingAddressId  String?
  billingAddress     Address?    @relation("BillingAddress", fields: [billingAddressId], references: [id])
  billingAddressId   String?

  orderItems         OrderItem[]
  @@index([userId])
  @@index([status])
  @@index([placedAt])
  @@index([couponId])
  @@index([branchId])
  @@index([shippingAddressId])
  @@index([billingAddressId])
  @@index([userId, status, placedAt])
}

model OrderItem {
  id        String      @id @default(uuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  item      Item    @relation(fields: [itemId], references: [id])
  itemId    String
  quantity  Int     @default(1)
  price     Float   // snapshot of price at purchase
  @@index([orderId])
  @@index([itemId])
  @@index([price])
  @@index([quantity])
}

model Branch {
  id      String      @id @default(uuid())
  name    String
  address String
  city    String
  state   String
  phone   String
  createdAt DateTime @default(now())

  inventory Inventory[]
  orders    Order[]
  employees Employee[]  // not User[]
   // Relationships
  reviews     Review[]  // One-to-many
  images      Image[]   // One-to-many
}

model Inventory {
  id        String      @id @default(uuid())
  itemId    String
  branchId  String
  quantity  Int
  updatedAt DateTime @updatedAt

  item      Item   @relation(fields: [itemId], references: [id])
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Employee {
  id          String      @id @default(uuid())
  userId       String     @unique
  branchId     String
  position     String  // like 'cashier', 'manager', etc.
  companyEmail String?
  isActive     Boolean  @default(true)
  user         User    @relation(fields: [userId], references: [id])
  branch       Branch  @relation(fields: [branchId], references: [id])
  @@index([branchId])
  @@index([isActive])
}


model JoinUs{
  id    String      @id @default(uuid())
  name String
  email String
}

model ContactUs{
  id    String      @id @default(uuid())
  name String
  email String
  subject String?
}

model Image {
  id          String         @id @default(uuid())
  imageUrl    String         @db.Text
  publicId    String         @unique
  ownerType   ImageOwnerType  // ← tells the API which FK is active
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  itemId      String?
  item        Item?          @relation(fields: [itemId], references: [id])
  branchId    String?
  branch      Branch?        @relation(fields: [branchId], references: [id])
  reviewId    String?
  review      Review?        @relation(fields: [reviewId], references: [id])
  uploadedAt  DateTime       @default(now())
  @@index([ownerType, userId])     // fetch all images for a user instantly
  @@index([ownerType, itemId])     // fetch all images for an item instantly
  @@index([ownerType, branchId])
  @@index([ownerType, reviewId])
}

model Review {
  id         String      @id @default(uuid())
  content    String
  rating     Int      // Rating between 1–5
  user       User     @relation(fields: [userId], references: [id])
  userId     String

  item       Item?    @relation(fields: [itemId], references: [id])
  itemId     String?

  branch     Branch?  @relation(fields: [branchId], references: [id])
  branchId   String?

  images     Image[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, itemId])    // one review per user per item
  @@unique([userId, branchId])  // one review per user per branch
  @@index([itemId])
  @@index([branchId])
  @@index([userId])
  @@index([rating])
}
model Cart {
  id        String      @id @default(uuid())
  name      String     // Optional: "Bulk Order", "Gift", etc.
  user      User?       @relation(fields: [userId], references: [id])
  userId    String?
  guestId   String?    
  createdAt DateTime   @default(now())
  isActive  Boolean    @default(true)

  items     CartItem[]
  @@unique([userId, isActive])
  @@unique([guestId, isActive]) // ✅ Added guest constraint

  @@index([userId])
  @@index([guestId])
  @@index([isActive])
}


model NewsletterSubscriber {
  id                String   @id @default(uuid())

  // Core identity
  email             String   @unique
  name              String?
  phone             String?

  // Funnel & lifecycle
  isActive           Boolean  @default(true)
  isUser             Boolean  @default(false)

  source             SubscriptionSource

  // Segmentation & analytics
  tags               Json?
  subscribedAt       DateTime @default(now())
  unsubscribedAt     DateTime?

  lastEmailSentAt    DateTime?

  @@index([isActive])
  @@index([isUser])
  @@index([source])
}